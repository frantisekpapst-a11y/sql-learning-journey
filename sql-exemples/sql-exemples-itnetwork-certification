📗 Lekce 6 — SELECT / WHERE / LIKE / IN / BETWEEN
Query #1 — SELECT *
SELECT *
FROM produkty;
Query #2 — Konkrétní sloupce
SELECT nazev, cena
FROM produkty;
Query #3 — WHERE
SELECT *
FROM produkty
WHERE cena > 5000;
Query #4 — AND
SELECT *
FROM produkty
WHERE cena > 1000
AND skladem > 5;
Query #5 — OR
SELECT *
FROM produkty
WHERE kategorie = 'Nábytek'
OR cena > 20000;
Query #6 — LIKE
SELECT *
FROM produkty
WHERE nazev LIKE '%Samsung%';
Query #7 — IN
SELECT *
FROM produkty
WHERE kategorie IN ('Elektronika', 'Doplňky');
Query #8 — BETWEEN
SELECT *
FROM produkty
WHERE cena BETWEEN 1000 AND 10000;
Query #9 — TOP
SELECT TOP 3 *
FROM produkty;

📗 Lekce 7 — ORDER BY / DISTINCT / NULL
Query #1 — ORDER BY DESC
SELECT *
FROM produkty
ORDER BY cena DESC;
Query #2 — DISTINCT
SELECT DISTINCT kategorie
FROM produkty;

👉 unikátní hodnoty

Query #3 — IS NULL
SELECT *
FROM produkty
WHERE sleva IS NULL;

📗 Lekce 8 — GROUP BY / Agregace
Query #1 — COUNT
SELECT COUNT(*) AS pocet_produktu
FROM produkty;
Query #2 — AVG
SELECT AVG(cena) AS prumerna_cena
FROM produkty;
Query #3 — SUM + GROUP BY
SELECT
    kategorie,
    SUM(cena) AS celkem
FROM produkty
GROUP BY kategorie;
Query #4 — HAVING
SELECT
    kategorie,
    COUNT(*) AS pocet
FROM produkty
GROUP BY kategorie
HAVING COUNT(*) > 3;

📗 Lekce 9 — JOIN
Query #1 — INNER JOIN
SELECT
    c.customer_name,
    o.amount
FROM customers c
INNER JOIN orders o
    ON c.customer_id = o.customer_id;
Query #2 — LEFT JOIN
SELECT
    c.customer_name,
    o.amount
FROM customers c
LEFT JOIN orders o
    ON c.customer_id = o.customer_id;
Query #3 — LEFT JOIN + COUNT
SELECT
    c.customer_name,
    COUNT(o.order_id) AS total_orders
FROM customers c
LEFT JOIN orders o
    ON c.customer_id = o.customer_id
GROUP BY c.customer_name;

👉 správné použití COUNT u LEFT JOIN

Query #4 — Zákazníci bez objednávky
SELECT
    c.customer_name
FROM customers c
LEFT JOIN orders o
    ON c.customer_id = o.customer_id
WHERE o.order_id IS NULL;
Query #5 — COALESCE
SELECT
    c.customer_name,
    COALESCE(SUM(o.amount), 0) AS revenue
FROM customers c
LEFT JOIN orders o
    ON c.customer_id = o.customer_id
GROUP BY c.customer_name;

📗 Lekce 10 — JOIN přes více tabulek / M:N
Query #1 — Více JOINů
SELECT
    s.name,
    c.course_name
FROM students s
JOIN student_courses sc
    ON s.student_id = sc.student_id
JOIN courses c
    ON sc.course_id = c.course_id;
Query #2 — LEFT JOIN přes M:N
SELECT
    s.name,
    c.course_name
FROM students s
LEFT JOIN student_courses sc
    ON s.student_id = sc.student_id
LEFT JOIN courses c
    ON sc.course_id = c.course_id;
Query #3 — Studenti bez kurzu
SELECT
    s.name
FROM students s
LEFT JOIN student_courses sc
    ON s.student_id = sc.student_id
WHERE sc.course_id IS NULL;
Query #4 — Počet kurzů na studenta
SELECT
    s.name,
    COUNT(c.course_id) AS number_courses
FROM students s
LEFT JOIN student_courses sc
    ON s.student_id = sc.student_id
LEFT JOIN courses c
    ON sc.course_id = c.course_id
GROUP BY s.name;
Query #5 — Podmínka v ON
SELECT
    s.name,
    c.course_name
FROM students s
LEFT JOIN student_courses sc
    ON s.student_id = sc.student_id
LEFT JOIN courses c
    ON sc.course_id = c.course_id
   AND c.course_name = 'SQL';

👉 LEFT JOIN zůstane zachovaný

📗 Lekce 11 — Poddotazy / EXISTS / CTE
Query #1 — Poddotaz v WHERE
SELECT *
FROM orders
WHERE amount > (
    SELECT AVG(amount)
    FROM orders
);
Query #2 — IN
SELECT *
FROM orders
WHERE customer_id IN (
    SELECT customer_id
    FROM customers
    WHERE country = 'DE'
);
Query #3 — EXISTS
SELECT *
FROM customers c
WHERE EXISTS (
    SELECT *
    FROM orders o
    WHERE c.customer_id = o.customer_id
);
Query #4 — NOT EXISTS
SELECT *
FROM customers c
WHERE NOT EXISTS (
    SELECT *
    FROM orders o
    WHERE c.customer_id = o.customer_id
);
Query #5 — Poddotaz jako tabulka
SELECT
    c.name,
    revenue.total_revenue
FROM (
    SELECT
        customer_id,
        SUM(amount) AS total_revenue
    FROM orders
    GROUP BY customer_id
) revenue
JOIN customers c
    ON revenue.customer_id = c.customer_id;
Query #6 — CTE
WITH customer_revenue AS (
    SELECT
        customer_id,
        SUM(amount) AS total_revenue
    FROM orders
    GROUP BY customer_id
)

SELECT
    c.name,
    cr.total_revenue
FROM customer_revenue cr
JOIN customers c
    ON cr.customer_id = c.customer_id;
Query #7 — Maximum přes CTE
WITH customer_revenue AS (
    SELECT
        customer_id,
        SUM(amount) AS total_revenue
    FROM orders
    GROUP BY customer_id
),

max_revenue AS (
    SELECT
        MAX(total_revenue) AS max_value
    FROM customer_revenue
)

SELECT
    c.name,
    cr.total_revenue
FROM customer_revenue cr
JOIN customers c
    ON cr.customer_id = c.customer_id
CROSS JOIN max_revenue mr
WHERE cr.total_revenue = mr.max_value;

👉 zákazník s nejvyšším revenue
