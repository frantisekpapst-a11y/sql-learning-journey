📗 Lekce 11 — Poddotazy / EXISTS / CTE
Query #1 — Poddotaz v WHERE
SELECT *
FROM orders
WHERE amount > (
    SELECT AVG(amount)
    FROM orders
);
Query #2 — IN
SELECT *
FROM orders
WHERE customer_id IN (
    SELECT customer_id
    FROM customers
    WHERE country = 'DE'
);
Query #3 — EXISTS
SELECT *
FROM customers c
WHERE EXISTS (
    SELECT *
    FROM orders o
    WHERE c.customer_id = o.customer_id
);
Query #4 — NOT EXISTS
SELECT *
FROM customers c
WHERE NOT EXISTS (
    SELECT *
    FROM orders o
    WHERE c.customer_id = o.customer_id
);
Query #5 — Poddotaz jako tabulka
SELECT
    c.name,
    revenue.total_revenue
FROM (
    SELECT
        customer_id,
        SUM(amount) AS total_revenue
    FROM orders
    GROUP BY customer_id
) revenue
JOIN customers c
    ON revenue.customer_id = c.customer_id;
Query #6 — CTE
WITH customer_revenue AS (
    SELECT
        customer_id,
        SUM(amount) AS total_revenue
    FROM orders
    GROUP BY customer_id
)

SELECT
    c.name,
    cr.total_revenue
FROM customer_revenue cr
JOIN customers c
    ON cr.customer_id = c.customer_id;
Query #7 — Maximum přes CTE
WITH customer_revenue AS (
    SELECT
        customer_id,
        SUM(amount) AS total_revenue
    FROM orders
    GROUP BY customer_id
),

max_revenue AS (
    SELECT
        MAX(total_revenue) AS max_value
    FROM customer_revenue
)

SELECT
    c.name,
    cr.total_revenue
FROM customer_revenue cr
JOIN customers c
    ON cr.customer_id = c.customer_id
CROSS JOIN max_revenue mr
WHERE cr.total_revenue = mr.max_value;

